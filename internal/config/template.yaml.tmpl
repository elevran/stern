# stern.yaml — configuration for the stern GitHub PR bot
# Generated by: stern config init
#
# After editing, validate with: stern config check
# Sync labels to the repo with: stern config sync-labels

org: {{ .Org }}
repo: {{ .Repo }}
bot_login: github-actions[bot]

# Enable plugins by listing their names here.
# Available plugins:
#   lgtm           — /lgtm and /lgtm cancel commands; LGTM label management
#   approve        — /approve and /approve cancel; requires OWNERS files
#   hold           — /hold and /hold cancel; blocks auto-merge
#   wip            — /wip toggle; WIP detection from PR title and draft state
#   cherry-pick    — /cherry-pick <sha> command for backporting
#   review_assignment — automatic reviewer assignment via OWNERS files
#   size           — automatic size/* labels based on diff size
#   lifecycle      — stale/rotten label management via scheduled runs
plugins: []

merge:
  # strategy: native  — GitHub's built-in auto-merge (requires branch protection)
  # strategy: bot     — bot account merges directly when eligible
  strategy: native

  # method: squash | merge | rebase
  method: squash

  # Labels that block auto-merge from being enabled.
  blocking_labels:
    - "do-not-merge/hold"
    - "do-not-merge/work-in-progress"
    - "needs-rebase"

lgtm:
  # Allow the PR author to LGTM their own PR.
  allow_self_lgtm: false
  # Remove lgtm label when new commits are pushed.
  invalidate_on_push: true

approve:
  # Allow the PR author to approve their own PR.
  allow_self_approval: false
  # Remove approved label when new commits are pushed.
  invalidate_on_push: false
  # Require the commenter to appear in an OWNERS file.
  require_owner: true

cherry_pick:
  # Regex pattern for branches that accept cherry-picks (e.g. "^release-.*").
  allowed_branch_pattern: ""
  # Slash command verb: cherry-pick | cherrypick | cp
  command: cherry-pick

review_assignment:
  enabled: false
  # load_balancing: round-robin | least-busy
  load_balancing: round-robin

lifecycle:
  # Days before an issue/PR is labeled lifecycle/stale.
  stale_days: 90
  # Days after stale before lifecycle/rotten.
  rotten_days: 30
  # Close rotten issues/PRs automatically.
  close_rotten: false

# Label definitions — reconciled with the repo by: stern config sync-labels
label_definitions:
  - name: lgtm
    color: "0e8a16"
    description: "Looks good to me"
  - name: approved
    color: "0e8a16"
    description: "Approved by an approver"
  - name: do-not-merge/hold
    color: "e11d48"
    description: "Block merging until this label is removed"
  - name: do-not-merge/work-in-progress
    color: "e11d48"
    description: "PR is not ready for review or merge"
  - name: needs-rebase
    color: "e4e669"
    description: "PR branch needs to be rebased on the target branch"
  - name: needs-triage
    color: "e4e669"
    description: "Issue needs triage before a PR will be accepted"
  - name: size/XS
    color: "3cbf00"
    description: "Fewer than 10 lines changed"
  - name: size/S
    color: "5d9801"
    description: "10-29 lines changed"
  - name: size/M
    color: "7f7203"
    description: "30-99 lines changed"
  - name: size/L
    color: "a14c05"
    description: "100-499 lines changed"
  - name: size/XL
    color: "c32607"
    description: "500-999 lines changed"
  - name: size/XXL
    color: "e50009"
    description: "1000 or more lines changed"
  - name: lifecycle/stale
    color: "cccccc"
    description: "Issue has not been active recently"
  - name: lifecycle/rotten
    color: "999999"
    description: "Issue has become rotten due to inactivity"
  - name: lifecycle/frozen
    color: "666666"
    description: "Issue is frozen and will not become stale"
